{
  "short_name": "進化小恐龍",
  "name": "小恐龍：進化與彩色雲",
  "icons": [
    {
      "src": "https://cdn-icons-png.flaticon.com/512/2972/2972185.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any maskable"
    }
  ],
  "start_url": "index.html",
  "background_color": "#ffffff",
  "display": "standalone",
  "scope": "./",
  "theme_color": "#e0f7fa",
  "orientation": "landscape"
}<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>小恐龍：進化 APP 版</title>
    <link rel="manifest" href="manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <style>
        * { user-select: none; -webkit-tap-highlight-color: transparent; }
        body { margin: 0; padding: 0; display: flex; justify-content: center; align-items: center; height: 100vh; background-color: #e0f7fa; font-family: sans-serif; overflow: hidden; touch-action: manipulation; }
        #game-container { position: relative; width: 100vw; max-width: 800px; height: 250px; background-color: white; border-bottom: 2px solid #535353; overflow: hidden; box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        
        /* 恐龍與進化 */
        #dino { position: absolute; bottom: 0; left: 50px; width: 40px; height: 43px; background-color: #535353; border-radius: 4px; z-index: 10; transition: background 0.3s; }
        #dino.evo-gold { background-color: #FFD700; box-shadow: 0 0 15px #FFD700; }
        #dino.evo-flame { background-color: #ff4757; box-shadow: 0 0 25px #ff6b81; animation: flamePulse 0.5s infinite alternate; }
        @keyframes flamePulse { from { transform: scale(1); } to { transform: scale(1.05); } }

        /* 特效粒子 */
        .particle { position: absolute; width: 6px; height: 6px; background: #ffa502; border-radius: 50%; z-index: 9; animation: particleFly 0.6s forwards; }
        @keyframes particleFly { to { opacity: 0; transform: translate(-20px, -40px); } }

        /* 障礙物與雲 */
        .obstacle { position: absolute; bottom: 0; z-index: 5; background-color: #535353; }
        .bird { bottom: 60px; border-radius: 50% 50% 0 0; }
        .cloud { position: absolute; border-radius: 50px; z-index: 1; opacity: 0.8; animation: cloudDrift linear infinite; }
        @keyframes cloudDrift { from { left: 110%; } to { left: -20%; } }

        /* UI */
        #ui { position: absolute; top: 10px; width: 100%; display: flex; justify-content: space-between; padding: 0 15px; box-sizing: border-box; font-weight: bold; color: #535353; z-index: 20; pointer-events: none; }
        #msg { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; display: none; z-index: 30; background: rgba(255,255,255,0.9); padding: 20px; border-radius: 10px; border: 2px solid #535353; }
    </style>
</head>
<body>

    <div id="game-container">
        <div id="ui">
            <div id="evo-status">幼年體</div>
            <div id="score">SCORE: 00000</div>
        </div>
        <div id="dino"></div>
        <div id="msg">
            <h1>GAME OVER</h1>
            <p>點擊螢幕重新挑戰</p>
        </div>
    </div>

<script>
    const container = document.getElementById('game-container');
    const dinoEl = document.getElementById('dino');
    const scoreEl = document.getElementById('score');
    const statusEl = document.getElementById('evo-status');
    const msgEl = document.getElementById('msg');

    let isRun = true, score = 0, speed = 6, evo = 'normal';
    let dino = { x: 50, y: 0, vy: 0, w: 40, h: 43, jump: false };
    let obs = [], clouds = [], timer = 0, cTimer = 0;

    // 觸控與鍵盤監聽
    const action = (e) => {
        if (e.type === 'touchstart') e.preventDefault();
        if (!isRun) reset();
        else if (!dino.jump) { dino.vy = -16; dino.jump = true; }
    };
    document.addEventListener('touchstart', action, {passive: false});
    document.addEventListener('keydown', (e) => { if(e.code === 'Space') action(e); });

    function loop() {
        if (!isRun) return;
        
        // 恐龍邏輯
        dino.vy += 0.8; dino.y -= dino.vy;
        if (dino.y <= 0) { dino.y = 0; dino.vy = 0; dino.jump = false; }
        dinoEl.style.bottom = dino.y + 'px';

        // 進化邏輯
        score++;
        let s = Math.floor(score/5);
        scoreEl.innerText = `SCORE: ${s.toString().padStart(5, '0')}`;
        
        if (s >= 1000 && evo !== 'flame') {
            evo = 'flame'; dinoEl.className = 'evo-flame'; statusEl.innerText = '火焰進化 (無敵)'; statusEl.style.color = '#ff4757';
        } else if (s >= 500 && s < 1000 && evo !== 'gold') {
            evo = 'gold'; dinoEl.className = 'evo-gold'; statusEl.innerText = '金色覺醒'; statusEl.style.color = '#FFD700';
        }

        if (evo === 'flame' && score % 5 === 0) createPart();

        // 障礙物與雲朵
        updateObs();
        updateClouds();
        if (evo !== 'flame') checkCol();

        requestAnimationFrame(loop);
    }

    function createPart() {
        const p = document.createElement('div'); p.className = 'particle';
        p.style.left = (dino.x + 10 + Math.random()*20)+'px'; p.style.bottom = (dino.y + Math.random()*30)+'px';
        container.appendChild(p); setTimeout(() => p.remove(), 600);
    }

    function updateObs() {
        for (let i = obs.length-1; i>=0; i--) {
            obs[i].x -= speed; obs[i].el.style.left = obs[i].x + 'px';
            if (obs[i].x < -50) { obs[i].el.remove(); obs.splice(i,1); }
        }
        if (++timer > (100 - speed)) {
            let type = Math.random() > 0.7 ? 'bird' : 'cactus';
            let h = type === 'bird' ? 30 : 50, w = type === 'bird' ? 40 : 25, y = type === 'bird' ? 70 : 0;
            const el = document.createElement('div'); el.className = 'obstacle ' + (type === 'bird' ? 'bird' : '');
            el.style.width = w+'px'; el.style.height = h+'px'; el.style.left = '100%'; el.style.bottom = y+'px';
            container.appendChild(el);
            obs.push({ el, x: container.offsetWidth, y, w, h });
            timer = 0;
        }
        if (score % 1000 === 0) speed += 0.5;
    }

    function updateClouds() {
        if (++cTimer > 100) {
            const c = document.createElement('div'); c.className = 'cloud';
            const colors = ['#ffffff', '#ffedff', '#e3f2fd', '#e8f5e9'];
            let w = 60+Math.random()*60;
            c.style.width = w+'px'; c.style.height = (w*0.4)+'px'; c.style.background = colors[Math.floor(Math.random()*4)];
            c.style.top = (20+Math.random()*80)+'px'; c.style.animationDuration = (15+Math.random()*15)+'s';
            container.appendChild(c); cTimer = 0;
            setTimeout(() => c.remove(), 30000);
        }
    }

    function checkCol() {
        let d = { l: dino.x+5, r: dino.x+dino.w-5, t: dino.y+dino.h, b: dino.y };
        for (let o of obs) {
            if (d.r > o.x+2 && d.l < o.x+o.w-2 && d.t > o.y && d.b < o.y+o.h) { isRun = false; msgEl.style.display = 'block'; }
        }
    }

    function reset() {
        score = 0; speed = 6; evo = 'normal'; dino.y = 0; dino.vy = 0; isRun = true;
        msgEl.style.display = 'none'; dinoEl.className = ''; statusEl.innerText = '幼年體';
        obs.forEach(o => o.el.remove()); obs = [];
        loop();
    }

    loop();
</script>
</body>
</html>
